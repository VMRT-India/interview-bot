POSTGRES_URL=postgresql+asyncpg://interview:interview@localhost:5432/interview_bot
MONGO_URL=mongodb://localhost:27017
MONGO_DB=interview_bot
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=120

# LLM provider: "groq" | "gemini" | "mlx"
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# App-default Gemini — two keys for failover under load (2nd is optional, only used
# if the first request fails). Get keys at https://aistudio.google.com/apikey.
# gemini-2.5-flash-lite is deliberately the cheapest current Gemini model.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash-lite

# MLX-LM (local dev) / vLLM (production) — update port when MLX-LM is installed
LLM_BASE_URL=http://localhost:__MLX_PORT__/v1
LLM_MODEL_NAME=local-model

# Tavily search API — company-specific interview-style lookup
TAVILY_API_KEY=

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

LOG_LEVEL=INFO
# Absolute last-resort circuit breaker, not the normal termination path
MAX_INTERVIEW_TURNS=40

# Phase 8 — adaptive interview length (see prompts/interviewer.py, api/routers/interview_ws.py)
DEFAULT_INTERVIEW_TARGET_MINUTES=45
INTERVIEW_OVERRUN_FACTOR=1.3

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# BYOK — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_MASTER_KEY=

# Kaggle API — used only by scripts/fetch_external_datasets.py (one-off dataset pull)
KAGGLE_USERNAME=
KAGGLE_KEY=

# OAuth — fill in once you've registered apps with each provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
# Default matches this backend's own /auth/{provider}/callback route (direct-backend
# testing). For the frontend SPA flow, set base_url to the frontend origin and this to
# /oauth/callback/{provider} instead (must match a registered redirect URI + a real
# frontend route) — see frontend/README.md.
OAUTH_CALLBACK_PATH_TEMPLATE=/auth/{provider}/callback

# Frontend origin(s) allowed to call this API (CORS), comma-separated if multiple
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]
